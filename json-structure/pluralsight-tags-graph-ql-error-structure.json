{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/pluralsight/refs/heads/main/json-structure/pluralsight-tags-graph-ql-error-structure.json",
  "name": "GraphQLError",
  "description": "GraphQLError from Pluralsight API",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "Error message",
      "example": "example_value"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "line": {
            "type": "int32"
          },
          "column": {
            "type": "int32"
          }
        }
      }
    },
    "path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}