{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/pluralsight/refs/heads/main/json-structure/pluralsight-tags-graph-ql-request-structure.json",
  "name": "GraphQLRequest",
  "description": "GraphQLRequest from Pluralsight API",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "The GraphQL query string",
      "example": "example_value"
    },
    "variables": {
      "type": "object",
      "description": "Variables for the GraphQL query"
    },
    "operationName": {
      "type": "string",
      "description": "Name of the operation to execute",
      "example": "Example Course"
    }
  },
  "required": [
    "query"
  ]
}