{
  "opencollection": "1.0.0",
  "info": {
    "name": "Pluralsight Flow Integrations API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Integrations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Pluralsight List Integrations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{workspace}.appfireflow.com/v3/customer/core/integrations",
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve a list of Flow integrations and check connection status with external tools and services."
        }
      ]
    }
  ],
  "bundled": true
}