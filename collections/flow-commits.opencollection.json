{
  "opencollection": "1.0.0",
  "info": {
    "name": "Pluralsight Flow Commits API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Commits",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Pluralsight Get Commits",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{workspace}.appfireflow.com/v3/customer/core/commits",
            "params": [
              {
                "name": "start_date",
                "value": "2026-04-17T12:00:00Z",
                "type": "query",
                "description": "Start date for the query period"
              },
              {
                "name": "end_date",
                "value": "2026-04-17T12:00:00Z",
                "type": "query",
                "description": "End date for the query period"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve commit data and aggregated commit metrics across repositories."
        }
      ]
    }
  ],
  "bundled": true
}